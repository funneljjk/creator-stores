# ── runmoa API credentials ────────────────────────────────────────────────
# Your runmoa site host, e.g. your-site.runmoa.com (no protocol, no slash)
RUNMOA_SITE_HOST=

# Storefront key (browser-safe, read-only). Format: moa_pub_xxxxxxxx
# Used by the homepage frontend to read site + contents.
RUNMOA_STOREFRONT_KEY=

# Server private key (SECRET — never expose to a browser).
# Used by the ingest pipeline to create/update contents.
RUNMOA_SERVER_KEY=

# ── pipeline defaults (optional) ──────────────────────────────────────────
# Existing content category id to file the imported videos under.
# The runmoa API cannot create categories, so this must already exist on the
# site. If empty, the pipeline tries to match/pick one automatically.
RUNMOA_CATEGORY_ID=

# Default publish status for created contents: pending | publish
RUNMOA_CONTENT_STATUS=pending
